{
  "name": "@knowledgeislands/mcp-ki-kb-fs",
  "description": "MCP for Knowledge Islands knowledge bases on a local filesystem",
  "version": "0.9.0",
  "author": "kris@kris.me.uk",
  "bin": {
    "mcp-ki-kb-fs": "dist/mcp-server/index.js"
  },
  "bugs": {
    "url": "https://github.com/knowledgeislands/mcp-ki-kb-fs/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "knip": "^6.29.0",
    "lint-staged": "^17.1.1",
    "markdownlint-cli2": "^0.23.1",
    "mcporter": "^0.12.3",
    "prettier": "^3.9.6",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/mcp-server/index.d.ts",
      "import": "./dist/mcp-server/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./notes": {
      "types": "./dist/main/notes/index.d.ts",
      "import": "./dist/main/notes/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/knowledgeislands/mcp-ki-kb-fs#readme",
  "keywords": [
    "anthropic",
    "claude",
    "knowledge-base",
    "markdown",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "bunx @biomejs/biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2 --no-globs"
    ]
  },
  "main": "dist/mcp-server/index.js",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/mcp-ki-kb-fs.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf {dist,node_modules}",
    "ki:audit": "bun .ki-meta/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-authoring",
    "ki:authoring:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-authoring",
    "ki:conform": "bun .ki-meta/bin/aggregate.ts conform",
    "ki:educate": "bun .ki-meta/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-engineering",
    "ki:engineering:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-engineering",
    "ki:generate:client": "mcporter emit-ts mcp-ki-kb-mcp-ki-kb-fs --mode client --out src/generated/client.ts --types-out src/generated/types.d.ts && printf '// @ts-nocheck\\n' | cat - src/generated/client.ts > /tmp/gen-tmp.ts && mv /tmp/gen-tmp.ts src/generated/client.ts",
    "ki:help": "bun .ki-meta/bin/aggregate.ts help",
    "ki:mcp:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-mcp",
    "ki:mcp:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-mcp",
    "ki:repo:audit": "bun .ki-meta/bin/aggregate.ts audit --skill ki-repo",
    "ki:repo:conform": "bun .ki-meta/bin/aggregate.ts conform --skill ki-repo",
    "ki:server:mcp:dev": "NODE_ENV=development bun --watch src/mcp-server/index.ts",
    "ki:server:mcp:inspect": "NODE_ENV=development bunx @modelcontextprotocol/inspector bun src/mcp-server/index.ts",
    "ki:server:mcp:start": "bun run build && node dist/mcp-server/index.js",
    "ki:test:smoke": "bun run build && bun scripts/smoke.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "type": "module"
}
