# Knowledge Base Configuration

# Absolute path or "~/..." to the knowledge base root directory.
# The server validates all tool paths against this root and rejects any traversal outside it.
MCP_KB_FS_ROOT_PATH=~/your-kb

# Comma-separated roles to enable. Allowed values: viewer, editor.
# Default when unset is `viewer` only (least privilege — read-only tools).
# Set to `viewer,editor` to also expose the destructive editor_* tools.
# MCP_KB_FS_ROLES=viewer,editor
