# Build output
dist/

# Coverage output
coverage/

# Dependency directories
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables — ignore everything except .env*.example templates
.env
.env.*
!.env*.example

# Tokens and credentials
*.pem
*.key
*.cert
*.token.json

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# OS specific files
.DS_Store
Thumbs.db

# Logs
logs
*.log
*.tsbuildinfo

# Project-local skills are generated by `skills:setup` (knowledgeislands-bootstrap), not committed.
.claude/skills/

# Generated project-local runtime payloads (ki-bootstrap) — never committed
.agents/skills/
